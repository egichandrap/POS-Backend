							"mode": "raw",
							"raw": "{\n    \"refresh_token\": \"{{refreshToken}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/token/refresh",
							"host": ["{{baseUrl}}"],
							"path": ["api", "token", "refresh"]
